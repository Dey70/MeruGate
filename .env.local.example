# Copy this file to .env.local and fill in real values.

# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Not used by the app today but
# kept for future admin/seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# platform.claude.com > API Keys
ANTHROPIC_API_KEY=
# Optional override — defaults to claude-sonnet-5 if unset.
ANTHROPIC_MODEL=claude-sonnet-5

# Used to build redirect URLs for magic link / OAuth. Update to your
# production domain when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
